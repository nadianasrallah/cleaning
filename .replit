run = [
    "deno",
    "run",
    "--lock=lock.json",
    "--lock-write",
    "--allow-all",
    "index.ts"
]

hidden = [".deno"]

entrypoint = "index.ts"
modules = ["nodejs-20", "python-3.11", "postgresql-16"]

[languages.deno]
pattern = "**/*.{ts,js}"
[languages.deno.languageServer]
start = ["deno", "lsp"]
[languages.deno.languageServer.initializationOptions]
enable = true
lint = true

[env]
DENO_DIR = "/home/runner/${REPL_SLUG}/.deno"

[nix]
channel = "stable-24_05"

[deployment]
run = ["deno", "run", "--lock=lock.json", "--allow-all index.ts"]
deploymentTarget = "cloudrun"
ignorePorts = false

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 3001
externalPort = 3002

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[[ports]]
localPort = 5002
externalPort = 4200

[[ports]]
localPort = 40285
externalPort = 3003

[agent]
expertMode = true
integrations = ["stripe:1.0.0", "resend:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "react-dev-server"

[[workflows.workflow]]
name = "react-dev-server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[userenv]

[userenv.shared]
SITE_PASSWORD = "test1234"
VITE_SITE_PASSWORD = "test1234"
